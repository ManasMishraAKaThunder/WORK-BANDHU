# Twilio OTP Verification Credentials
# Copy this file to .env and fill in your actual values.
# Get your credentials from https://console.twilio.com/
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
EXPO_PUBLIC_TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here
